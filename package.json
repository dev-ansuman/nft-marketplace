{
  "name": "nft-marketplace",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,js,json,css,md,tsx,jsx}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "**/*.{ts,js}": [
      "prettier --write",
      "eslint ."
    ],
    "**/*.{json,css,md}": [
      "prettier --write"
    ],
    "**/*.md": [
      "prettier --write"
    ]
  }
}